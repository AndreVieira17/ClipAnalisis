{
  "name": "xzk-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "ISOLATED Remotion sub-project. Renders the hero ambient loop to ../public. NEVER imported by the app bundle.",
  "scripts": {
    "studio": "remotion studio",
    "render:webm": "remotion render HeroLoop ../public/hero-loop.webm --codec=vp8 --image-format=png",
    "render:mp4": "remotion render HeroLoop ../public/hero-loop.mp4 --codec=h264",
    "render:poster": "remotion still HeroLoop ../public/hero-loop-poster.png --frame=60",
    "render": "npm run render:webm && npm run render:mp4"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
