# ---- Frontend (Vite) — safe to expose, anon key only ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ---- Supabase Edge Function secrets (set via `supabase secrets set`) ----
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically by the
# Edge runtime; you only need to set the AI key (and optionally the model).
# The backend uses the official @google/genai SDK, which accepts the current
# Gemini "auth keys" (prefix AQ.) as well as legacy AIza keys:
#   supabase secrets set GEMINI_API_KEY=AQ.xxxxx
#   supabase secrets set GEMINI_MODEL=gemini-2.5-flash   # optional override
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
